# First Cargo customer portal — copy to .env.local or .env.customer-app

# ── Agency & brand ──────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENCY_SLUG=first-cargo
NEXT_PUBLIC_APP_NAME=First Cargo
NEXT_PUBLIC_BRAND_PRIMARY=#263070
# Default URL locale when users open / without a locale prefix (en | fr | zh)
NEXT_PUBLIC_DEFAULT_LOCALE=en
# Optional env logo fallback — agency logo from API is preferred when set
# NEXT_PUBLIC_BRAND_LOGO_URL=https://cdn.example.com/first-cargo-logo.png

# Optional: full white-label preset (see config/portal.first-cargo.json)
# NEXT_PUBLIC_PORTAL_CONFIG_JSON=
# Mobile bottom tab style: classic | floating | pill | underline | solid
# NEXT_PUBLIC_PORTAL_BOTTOM_NAV_VARIANT=classic

# ── Portal content ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_PORTAL_NOTICE=Holiday hours: branches close at 2pm on Saturdays.
# NEXT_PUBLIC_SUPPORT_PHONE=+237 677 000 000
# NEXT_PUBLIC_SUPPORT_EMAIL=support@firstcargo.cm
# NEXT_PUBLIC_LOCATIONS_URL=https://firstcargo.cm/locations
# NEXT_PUBLIC_PORTAL_VERSION=1.0.0

# ── Feature flags (optional) ────────────────────────────────────────────────
# NEXT_PUBLIC_PORTAL_SHOW_NOTIFICATIONS=true
# NEXT_PUBLIC_PORTAL_SHOW_DRAWER=true
# NEXT_PUBLIC_PORTAL_SHOW_POWERED_BY=true
# NEXT_PUBLIC_PORTAL_SHOW_QUICK_ACTIONS=true
# NEXT_PUBLIC_PORTAL_SHOW_SHIPMENT_LIST=true

# ── PWA ─────────────────────────────────────────────────────────────────────
# Set to false to disable service worker generation (local debugging only).
# NEXT_PUBLIC_ENABLE_PWA=true

# ── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET=replace-with-strong-secret
NEXTAUTH_URL=http://localhost:3002

# ── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=/backend/api/v1
NEXT_PUBLIC_STAFF_APP_URL=http://localhost:3000
